{
  "name": "@dynatrace/cordova-plugin",
  "package": {
    "name": "@dynatrace/cordova-plugin",
    "version": "2.309.1",
    "description": "Dynatrace RUM Mobile plugin for Capacitor applications",
    "capacitor": {
      "ios": {
        "src": "ios"
      },
      "android": {
        "src": "android"
      }
    },
    "type": "capacitor"
  },
  "platforms": ["ios", "android"],
  "scripts": {
    "sync:ios": "node scripts/capacitor/CapacitorSync.js && node scripts/capacitor/CapacitorInstrument.js ios",
    "sync:android": "node scripts/capacitor/CapacitorSync.js && node scripts/capacitor/CapacitorInstrument.js android",
    "instrument:ios": "node scripts/capacitor/CapacitorInstrument.js ios",
    "instrument:android": "node scripts/capacitor/CapacitorInstrument.js android",
    "close": "node scripts/capacitor/CapacitorClose.js"
  },
  "hooks": {
    "ios": {
      "beforeSync": "scripts/capacitor/CapacitorSync.js",
      "afterSync": "scripts/capacitor/CapacitorInstrument.js",
      "afterBuild": "scripts/capacitor/CapacitorClose.js",
      "afterRun": "scripts/capacitor/CapacitorClose.js"
    },
    "android": {
      "beforeSync": "scripts/capacitor/CapacitorSync.js",
      "afterSync": "scripts/capacitor/CapacitorInstrument.js",
      "afterBuild": "scripts/capacitor/CapacitorClose.js",
      "afterRun": "scripts/capacitor/CapacitorClose.js"
    }
  }
}
