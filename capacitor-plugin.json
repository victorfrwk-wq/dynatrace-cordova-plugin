{
  "name": "@dynatrace/cordova-plugin",
  "package": {
    "name": "@dynatrace/cordova-plugin",
    "version": "2.309.1",
    "description": "Dynatrace RUM Mobile plugin for Capacitor applications",
    "type": "capacitor"
  },
  "platforms": ["ios", "android"],
  "scripts": {
    "sync:ios": "node scripts/InstallCap.js && node scripts/InstrumentCap.js --capacitor=ios",
    "sync:android": "node scripts/InstallCap.js && node scripts/InstrumentCap.js --capacitor=android",
    "instrument:ios": "node scripts/InstrumentCap.js --capacitor=ios",
    "instrument:android": "node scripts/InstrumentCap.js --capacitor=android",
    "close": "node scripts/CloseLog.js"
  },
  "hooks": {
    "ios": {
      "beforeSync": "scripts/InstallCap.js",
      "afterSync": "scripts/InstrumentCap.js",
      "afterBuild": "scripts/CloseLog.js",
      "afterRun": "scripts/CloseLog.js"
    },
    "android": {
      "beforeSync": "scripts/InstallCap.js",
      "afterSync": "scripts/InstrumentCap.js",
      "afterBuild": "scripts/CloseLog.js",
      "afterRun": "scripts/CloseLog.js"
    }
  }
}
